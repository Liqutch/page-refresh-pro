  "author": "Page Refresh Pro (me@liqutch.dev)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "icons:transparent": "node scripts/make-logo-transparent.mjs public/icons/logo.png",
    "preview": "vite preview"
  },
  "keywords": [
    "chrome-extension",
