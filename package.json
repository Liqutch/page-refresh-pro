  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@types/chrome": "^0.2.2",
    "sharp": "^0.35.3",
    "typescript": "^5.9.3",
    "vite": "^7.1.4"
  }
}
